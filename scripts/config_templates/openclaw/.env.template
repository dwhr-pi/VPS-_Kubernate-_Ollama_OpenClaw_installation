# OpenClaw .env Konfigurationsvorlage
# ==============================================================================
# Diese Datei kombiniert unsere bisherigen Setup-Werte mit der originalen
# OpenClaw-.env-Struktur.
#
# Schnellstart:
# 1) Diese Datei nach `.env` kopieren oder über den OpenClaw-Konfigurations-
#    Manager auf die OpenClaw-Installation anwenden.
# 2) Nur die Werte ausfüllen, die du wirklich nutzt.
# 3) Echte Geheimnisse niemals in Git speichern.
#
# Für eine ausführliche Erklärung dieser Datei siehe:
# docs/OPENCLAW_ENV_GUIDE.md
# Für API-Schlüssel siehe:
# docs/API_KEY_GUIDE.md
#
# Priorität der Umgebungsvariablen (höchste -> niedrigste):
# Prozess-Umgebung, ./ .env, ~/.openclaw/.env, danach der `env`-Block in
# `openclaw.json`.
# Bereits gesetzte, nicht-leere Prozessvariablen werden durch dotenv/config
# normalerweise nicht überschrieben.
# Hinweis: Direkte Config-Schlüssel wie `gateway.auth.token` oder Channel-Tokens
# in `openclaw.json` werden separat ausgewertet und haben oft Vorrang vor
# Umgebungsvariablen.
# ==============================================================================

# ------------------------------------------------------------------------------
# Allgemeine Laufzeit-Einstellungen
# ------------------------------------------------------------------------------

# Umgebung, in der OpenClaw läuft: development oder production
NODE_ENV=production

# Port, auf dem OpenClaw lauscht
PORT=3000

# Host-Binding
# Achtung: 0.0.0.0 öffnet OpenClaw auf allen Interfaces.
HOST=0.0.0.0

# Öffentliche Domain für externe Zugriffe und Callback-URLs
DOMAIN=https://botsoft.uk

# ------------------------------------------------------------------------------
# Gateway-Authentifizierung + Pfade (aus dem OpenClaw-Original)
# ------------------------------------------------------------------------------

# Empfohlen, wenn das Gateway nicht nur auf loopback lauscht.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Optionaler Generator:
# openssl rand -hex 32

# Alternative Authentifizierung: Entweder Token ODER Passwort verwenden.
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optionale Pfadüberschreibungen
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: Fehlende Variablen aus dem Login-Shell-Profil importieren
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# ------------------------------------------------------------------------------
# LLM-/Provider-Auswahl
# ------------------------------------------------------------------------------

# Historische Variable aus diesem Setup. Für Kompatibilität belassen.
# Empfohlene Werte in diesem Setup: GEMINI oder OLLAMA
PRIMÄRES_LLM_ANBIETER=GEMINI

# ASCII-Alternative für Skripte und künftige Vereinheitlichung
LLM_PROVIDER=

# ------------------------------------------------------------------------------
# Modellanbieter-API-Schlüssel (mindestens einen setzen)
# ------------------------------------------------------------------------------

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_1=
# OPENAI_API_KEYS=sk-1,sk-2

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_1=
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2

# Gemini / Google
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_KEY_1=
# GEMINI_API_KEYS=key-1,key-2
# GOOGLE_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Live-Schlüssel für OpenClaw-spezifische Modi
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=

# Zusätzliche optionale Provider
# ZAI_API_KEY=
# AI_GATEWAY_API_KEY=
# MINIMAX_API_KEY=
# SYNTHETIC_API_KEY=

# ------------------------------------------------------------------------------
# Ollama-Konfiguration
# ------------------------------------------------------------------------------

# Host und Port des Ollama-Servers
OLLAMA_HOST=http://localhost:11434

# Alternative Feldbezeichnung, die in Teilen dieses Setups ebenfalls verwendet wird
OLLAMA_BASE_URL=http://localhost:11434

# Standardmodell für lokale Nutzung
OLLAMA_MODEL=llama3.2:1b

# Auf true setzen, wenn Ollama als Fallback dienen soll, falls Gemini der primäre Anbieter ist
FALLBACK_TO_OLLAMA=true

# Auf true setzen, wenn Gemini als Fallback dienen soll, falls Ollama der primäre Anbieter ist
FALLBACK_TO_GEMINI=false

# ------------------------------------------------------------------------------
# Channels / Bots (nur setzen, wenn wirklich genutzt)
# ------------------------------------------------------------------------------

# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optionale weitere Channel-Fallbacks
# MATTERMOST_BOT_TOKEN=
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# ------------------------------------------------------------------------------
# Tools + Web + Voice/Media (optional)
# ------------------------------------------------------------------------------

# Recherche / Browser / Crawler
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=

# Voice / Speech
# ELEVENLABS_API_KEY=
# XI_API_KEY=   # Alias für ElevenLabs
# DEEPGRAM_API_KEY=

# ------------------------------------------------------------------------------
# Datenbank
# ------------------------------------------------------------------------------

# MongoDB-Verbindungsstring
DB_CONNECTION_STRING=mongodb://localhost:27017/openclaw

# ------------------------------------------------------------------------------
# Sicherheit & Authentifizierung
# ------------------------------------------------------------------------------

# JWT-Secret für lokale Auth-/Session-Zwecke
JWT_SECRET=

# Lokale Admin-Zugangsdaten
ADMIN_EMAIL=admin@botsoft.uk
ADMIN_PASSWORD=

# ------------------------------------------------------------------------------
# Cloudflare Tunnel
# ------------------------------------------------------------------------------

CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_SECRET=

# ------------------------------------------------------------------------------
# Google Kalender / Google OAuth
# ------------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://botsoft.uk/auth/google/callback

# ------------------------------------------------------------------------------
# Weitere projektspezifische Integrationen
# ------------------------------------------------------------------------------

HF_TOKEN=
KIMI_API_KEY=

# ------------------------------------------------------------------------------
# Reinforcement Learning / OpenClaw RL
# ------------------------------------------------------------------------------

RL_AGENT_ENABLED=false
RL_MODEL_PATH=/opt/openclaw-rl/models/default_rl_model.pth
RL_TRAINING_MODE=false

# ==============================================================================
# ENDE DER OPENCLAW .ENV KONFIGURATION
# ==============================================================================
