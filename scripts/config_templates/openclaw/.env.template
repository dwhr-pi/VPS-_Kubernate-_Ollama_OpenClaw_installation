# OpenClaw .env Konfigurationsvorlage
# ==============================================================================
# Diese Datei enthält Umgebungsvariablen für OpenClaw.
# Passe die Werte entsprechend deiner Umgebung an.
# ==============================================================================

# --- Allgemeine Einstellungen ---

# NODE_ENV: Umgebung, in der OpenClaw läuft (development, production)
NODE_ENV=production

# PORT: Der Port, auf dem OpenClaw läuft. Standard ist 3000.
# Stelle sicher, dass dieser Port auf deinem System frei ist und ggf. in der Firewall geöffnet ist.
PORT=3000

# HOST: Der Host, auf dem OpenClaw lauscht. Für alle Schnittstellen '0.0.0.0' verwenden.
HOST=0.0.0.0

# DOMAIN: Deine öffentliche Domain für OpenClaw. Wird für externe Zugriffe und Callbacks benötigt.
# Beispiel: https://botsoft.uk
DOMAIN=https://botsoft.uk

# --- KI-Modell Einstellungen ---

# PRIMÄRES_LLM_ANBIETER: Der primäre LLM-Anbieter (GEMINI oder OLLAMA)
# Für lokale Installationen mit Fallback: GEMINI
# Für reine Ollama-Installationen: OLLAMA
PRIMÄRES_LLM_ANBIETER=GEMINI

# --- GEMINI Konfiguration (wenn PRIMÄRES_LLM_ANBIETER=GEMINI) ---

# GEMINI_API_KEY: Dein Google Gemini API-Schlüssel.
# Erhältlich unter https://aistudio.google.com/app/apikey
GEMINI_API_KEY="DEIN_GEMINI_API_KEY_HIER"

# GEMINI_MODEL: Das zu verwendende Gemini-Modell (z.B. gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# --- OLLAMA Konfiguration (wenn PRIMÄRES_LLM_ANBIETER=OLLAMA oder als Fallback) ---

# OLLAMA_HOST: Host und Port deines Ollama-Servers (z.B. http://localhost:11434 oder http://192.168.1.100:11434)
# Für lokale Installationen: http://localhost:11434
# Für VPS-Installationen (wenn Ollama auf einem anderen Server läuft): IP_DES_OLLAMA_VPS:11434
OLLAMA_HOST=http://localhost:11434

# OLLAMA_MODEL: Das zu verwendende Ollama-Modell (z.B. llama3.2:1b, deepseek-coder, mistral)
# Stelle sicher, dass dieses Modell auf deinem Ollama-Server installiert ist.
OLLAMA_MODEL=llama3.2:1b

# --- Fallback-Einstellungen (wenn PRIMÄRES_LLM_ANBIETER=GEMINI) ---

# FALLBACK_TO_OLLAMA: Auf 'true' setzen, um Ollama als Fallback zu nutzen, wenn Gemini fehlschlägt.
FALLBACK_TO_OLLAMA=true

# --- Datenbank Konfiguration (Beispiel: MongoDB) ---

# DB_CONNECTION_STRING: MongoDB Verbindungsstring.
# Für lokale MongoDB: mongodb://localhost:27017/openclaw
# Für VPS MongoDB: mongodb://USER:PASS@IP_DER_DB:27017/openclaw
DB_CONNECTION_STRING="mongodb://localhost:27017/openclaw"

# --- Sicherheit & Authentifizierung (Platzhalter) ---

# JWT_SECRET: Ein langer, zufälliger String für JWT-Token (mind. 32 Zeichen).
# Generiere einen sicheren Schlüssel, z.B. mit 'openssl rand -base64 32'
JWT_SECRET="DEIN_SUPER_GEHEIMER_JWT_SCHLUESSEL_HIER"

# ADMIN_EMAIL: E-Mail-Adresse des Admin-Benutzers für OpenClaw.
ADMIN_EMAIL="admin@botsoft.uk"

# ADMIN_PASSWORD: Passwort des Admin-Benutzers für OpenClaw.
ADMIN_PASSWORD="DEIN_ADMIN_PASSWORT_HIER"

# --- Cloudflare Tunnel Konfiguration (für Alexa Skill oder externen Zugriff) ---

# CLOUDFLARE_TUNNEL_ID: Die ID deines Cloudflare Tunnels.
# Wird benötigt, wenn OpenClaw über einen Cloudflare Tunnel erreichbar sein soll.
CLOUDFLARE_TUNNEL_ID="DEIN_CLOUDFLARE_TUNNEL_ID_HIER"

# CLOUDFLARE_TUNNEL_SECRET: Der Secret-Token deines Cloudflare Tunnels.
CLOUDFLARE_TUNNEL_SECRET="DEIN_CLOUDFLARE_TUNNEL_SECRET_HIER"

# --- Google Kalender Skill (gcali) Konfiguration ---

# GOOGLE_CLIENT_ID: Deine Google Cloud Client ID für den Kalender-Zugriff.
# Erhältlich über die Google Cloud Console (APIs & Dienste -> Anmeldedaten).
GOOGLE_CLIENT_ID="DEINE_GOOGLE_CLIENT_ID_HIER"

# GOOGLE_CLIENT_SECRET: Dein Google Cloud Client Secret.
GOOGLE_CLIENT_SECRET="DEIN_GOOGLE_CLIENT_SECRET_HIER"

# GOOGLE_REDIRECT_URI: Die Redirect URI, die du in der Google Cloud Console konfiguriert hast.
# Muss mit deiner OpenClaw Domain übereinstimmen, z.B. https://botsoft.uk/auth/google/callback
GOOGLE_REDIRECT_URI="https://botsoft.uk/auth/google/callback"

# --- Weitere OpenClaw RL (Reinforcement Learning) Einstellungen (falls zutreffend) ---

# RL_AGENT_ENABLED: Auf 'true' setzen, um den RL-Agenten zu aktivieren.
RL_AGENT_ENABLED=false

# RL_MODEL_PATH: Pfad zum RL-Modell (z.B. /opt/openclaw-rl/models/my_rl_model.pth)
RL_MODEL_PATH="/opt/openclaw-rl/models/default_rl_model.pth"

# RL_TRAINING_MODE: Auf 'true' setzen, um den RL-Agenten im Trainingsmodus zu starten.
RL_TRAINING_MODE=false

# ==============================================================================
# ENDE DER OPENCLAW .ENV KONFIGURATION
# ==============================================================================
