ROBOTICS_HOME=~/Ultimate_KI_Setup/robotics_control
ROBOTICS_MODE=read_only
ALLOW_ACTUATOR_WRITES=0
REQUIRE_HUMAN_APPROVAL=1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
N8N_BASE_URL=http://127.0.0.1:5678
NODE_RED_URL=http://127.0.0.1:1880
HOME_ASSISTANT_URL=http://homeassistant.local:8123

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MODBUS_TCP_HOST=127.0.0.1
MODBUS_TCP_PORT=502
OPCUA_ENDPOINT=opc.tcp://127.0.0.1:4840

DEFAULT_ROBOTICS_MODEL=ollama/qwen2.5-coder
LOG_FORMAT=jsonl
SAFETY_COMMAND_WHITELIST=./configs/command_whitelist.yml

