# LLMOps Platform .env Konfigurationsvorlage
# Diese Datei ist die Repo-Vorlage. Die bearbeitbare Laufzeitkopie soll
# idealerweise ausserhalb des Repos unter ~/.openclaw_ultimate_user_data/
# gepflegt und dann als stacks/llmops-platform/.env angewendet werden.

LITELLM_MASTER_KEY=change-me-to-a-long-random-string
LITELLM_SALT_KEY=change-me-to-another-long-random-string
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OPENAI_API_KEY=
GEMINI_API_KEY=

OPENCLAW_LITELLM_BASE_URL=http://host.docker.internal:4000/v1
OPENCLAW_OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENCLAW_DEFAULT_MODEL=ollama-default

OPENWEBUI_SECRET_KEY=change-me-to-a-long-random-string
OPENWEBUI_PORT=3000

POSTGRES_DB=llmops
POSTGRES_USER=llmops
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

LANGFUSE_DATABASE_URL=postgresql://llmops:change-me@postgres:5432/llmops
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
LANGFUSE_HOST=http://127.0.0.1:3003

QDRANT_PORT=6333
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
UPTIME_KUMA_PORT=3004
NETDATA_PORT=19999
