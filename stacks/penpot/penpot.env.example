PENPOT_VERSION=latest
PENPOT_BIND_HOST=127.0.0.1
PENPOT_HOST_PORT=9011
PENPOT_MAILCATCH_PORT=1081
PENPOT_PUBLIC_URI=http://127.0.0.1:9011
PENPOT_FLAGS=enable-smtp disable-email-verification
PENPOT_HTTP_SERVER_MAX_BODY_SIZE=367001600
PENPOT_HTTP_SERVER_MAX_MULTIPART_BODY_SIZE=367001600
PENPOT_DATABASE_NAME=penpot
PENPOT_DATABASE_USERNAME=penpot
PENPOT_DATABASE_PASSWORD=change-me
PENPOT_SECRET_KEY=change-me
PENPOT_OBJECTS_STORAGE_BACKEND=fs
PENPOT_TELEMETRY_ENABLED=false
PENPOT_TELEMETRY_REFERER=openclaw-ultimate-setup
PENPOT_SMTP_DEFAULT_FROM=no-reply@example.local
PENPOT_SMTP_DEFAULT_REPLY_TO=no-reply@example.local
PENPOT_SMTP_HOST=penpot-mailcatch
PENPOT_SMTP_PORT=1025
PENPOT_SMTP_USERNAME=
PENPOT_SMTP_PASSWORD=
PENPOT_SMTP_TLS=false
PENPOT_SMTP_SSL=false
PENPOT_VALKEY_EXTRA_FLAGS=--maxmemory 128mb --maxmemory-policy volatile-lfu
