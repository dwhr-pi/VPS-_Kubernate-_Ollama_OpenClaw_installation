# Vereinheitlichte OpenClaw-.env-Vorlage für dieses Repository
# Basierend auf unserer Setup-Logik plus der originalen OpenClaw-.env
# Für Details siehe docs/OPENCLAW_ENV_GUIDE.md
# Für API-Schlüssel siehe docs/API_KEY_GUIDE.md

NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DOMAIN=https://botsoft.uk

# Gateway / Pfade
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# Aktuell im Repo historisch verwendet, aber mittelfristig auf ASCII-Namen vereinheitlichen
PRIMÄRES_LLM_ANBIETER=GEMINI
LLM_PROVIDER=

# Modellanbieter
# OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_1=
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_1=
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_KEY_1=
# GEMINI_API_KEYS=key-1,key-2
# GOOGLE_API_KEY=
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=
# ZAI_API_KEY=
# AI_GATEWAY_API_KEY=
# MINIMAX_API_KEY=
# SYNTHETIC_API_KEY=

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
FALLBACK_TO_OLLAMA=true

# Channels
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# MATTERMOST_BOT_TOKEN=
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# Tools / Voice / Media
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=
# ELEVENLABS_API_KEY=
# XI_API_KEY=
# DEEPGRAM_API_KEY=

# Datenbank / Auth
DB_CONNECTION_STRING=mongodb://localhost:27017/openclaw
JWT_SECRET=
ADMIN_EMAIL=admin@botsoft.uk
ADMIN_PASSWORD=

# Cloudflare / Google / weitere Integrationen
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://botsoft.uk/auth/google/callback
HF_TOKEN=
KIMI_API_KEY=

# RL
RL_AGENT_ENABLED=false
RL_MODEL_PATH=/opt/openclaw-rl/models/default_rl_model.pth
RL_TRAINING_MODE=false
